{
  "name": "hundred-yards-ops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c green,blue \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch apps/server/src/index.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsup apps/server/src/index.ts --format esm --out-dir dist/server --clean",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "test": "vitest run",
    "preview": "vite preview --config apps/web/vite.config.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vitest": "^3.2.4"
  }
}

